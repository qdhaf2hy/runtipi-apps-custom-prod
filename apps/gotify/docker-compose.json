{
  "services": [
    {
      "name": "gotify",
      "image": "gotify/server:2.9.1",
      "isMain": true,
      "internalPort": 80,
      "environment": [ ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/app/data"
        }
      ]
    }
  ],
  "overrides": [
    {
      "architecture": "arm64",
      "services": [
        {
          "name": "gotify",
          "image": "gotify/server-arm64:2.9.1"
        }
      ]
    }
  ],
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/v2/dynamic-compose.json"
}
